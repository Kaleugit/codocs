{
  "name": "codocs",
  "version": "0.1.0",
  "description": "Gera documentação técnica automaticamente a partir de código e histórico Git",
  "type": "module",
  "bin": {
    "codocs": "./dist/cli/index.js"
  },
  "main": "./dist/engine/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^2.12.0",
    "@viz-js/viz": "^3.28.0",
    "@vscode/tree-sitter-wasm": "^0.3.1",
    "commander": "^15.0.0",
    "marked": "^18.0.6",
    "mermaid": "^11.16.0",
    "ora": "^9.4.1",
    "puppeteer": "^25.3.0",
    "simple-git": "^3.36.0",
    "web-tree-sitter": "^0.26.11"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
